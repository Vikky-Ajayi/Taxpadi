{
  "version": 2,
  "buildCommand": "pnpm install && pnpm -w run build:vercel",
  "outputDirectory": "artifacts/taxpay/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/server.js": {
      "maxDuration": 30
    }
  }
}
