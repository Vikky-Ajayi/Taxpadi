{
  "version": 2,
  "buildCommand": "pnpm install && pnpm run build:vercel",
  "outputDirectory": "artifacts/taxpay/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" }
  ],
  "functions": {
    "api/server.ts": {
      "maxDuration": 30
    }
  }
}
